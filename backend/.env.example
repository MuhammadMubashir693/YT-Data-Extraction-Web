YT_API_KEY=YOUR_API_KEY
PORT=5000

# Option A: local/self-hosted Mongo — set these parts, MONGO_URI is built for you
MONGO_USER=admin
MONGO_PASS=mongo123
MONGO_HOST=localhost
MONGO_PORT=27017

# Option B: MongoDB Atlas (used on Render) — set the full connection string
# Atlas gives you instead; this overrides the parts above when set.
# MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority

MONGO_DB=yt-pool
MONGO_COLL_CHANNELS=yt-channels
MONGO_COLL_VIDEOS=yt-videos
MONGO_COLL_PLAYLISTS=yt-playlists
MONGO_COLL_COMMENTS=yt-comments